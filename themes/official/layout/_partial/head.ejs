<!doctype html>
<html lang="<%= page.lang || config.official_site.default_language %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="<%= page.description || config.description %>">
    <meta name="theme-color" content="#0f172a">
    <title><%= page.title ? page.title + ' | ' + config.title : config.title %></title>
    <% Object.keys(config.official_site.languages).forEach(function(code) { %>
      <link rel="alternate" hreflang="<%= code %>" href="<%= full_url_for(config.official_site.languages[code].path) %>">
    <% }) %>
    <link rel="stylesheet" href="<%- url_for('/css/style.css') %>">
  </head>
